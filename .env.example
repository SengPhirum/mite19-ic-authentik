# Copy this file to .env or use the generated .env included with this lab.
# For a server demo, replace localhost with the server IP or DNS name before first start.

PG_DB=authentik
PG_USER=authentik
PG_PASS=change-me-generate-with-openssl-rand-base64-36
AUTHENTIK_SECRET_KEY=change-me-generate-with-openssl-rand-base64-60
AUTHENTIK_TAG=2026.5.0
AUTHENTIK_ERROR_REPORTING__ENABLED=false

COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9443
AUTHENTIK_PUBLIC_URL=http://localhost:9000

GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_REDIRECT_URI=http://localhost:3000/login/generic_oauth
GRAFANA_ADMIN_PASSWORD=change-me

OIDC_CLIENT_ID=grafana-demo
OIDC_CLIENT_SECRET=change-me-generate-a-long-secret

DEMO_ADMIN_PASSWORD=change-me
DEMO_USER_PASSWORD=change-me
DEMO_OUTSIDER_PASSWORD=change-me

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# Optional automated akadmin bootstrap. Leave unset if you need to capture
# the official initial setup wizard screenshot.
# AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
# AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@example.local
